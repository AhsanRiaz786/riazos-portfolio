# GitHub personal access token (read:repo scope is enough)
# Used server-side in app/api/github/route.ts only. Never exposed to the client.
GITHUB_TOKEN=your_github_personal_access_token_here

# Vercel AI Gateway key (Phase 4 only - agent operator feature)
# Used server-side in app/api/agent/route.ts only. Never exposed to the client.
AI_GATEWAY_KEY=your_ai_gateway_key_here
